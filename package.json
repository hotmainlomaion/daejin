{
  "name": "futureslab",
  "private": true,
  "version": "0.1.0",
  "description": "선물 자동매매 모의투자 툴 — 바이낸스 테스트넷 전용 교육·검증 시뮬레이터",
  "workspaces": [
    "shared",
    "worker",
    "app"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "npm run dev --workspace=app",
    "worker": "npm run start --workspace=worker",
    "worker:dev": "npm run dev --workspace=worker",
    "build": "npm run build --workspace=app",
    "test": "vitest run --root .",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
