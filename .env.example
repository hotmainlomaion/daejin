# FuturesLab 환경변수 예시
# 이 파일을 .env.local(웹앱) / .env(워커)로 복사해서 채운다.
# ⚠️ NEXT_PUBLIC_ 접두사가 붙은 값만 브라우저로 나간다. 나머지는 절대 클라이언트 번들에 넣지 않는다.

# ── 웹앱 + 워커 공통 ─────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://sncwrgewemyncpfhyggq.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── 서버/워커 전용 (클라이언트 유입 금지) ────────────────
# RLS를 우회하므로 유출 시 전체 DB가 열린다.
SUPABASE_SERVICE_ROLE_KEY=

# 유저 테스트넷 키 암호화용. 32바이트 키의 hex(64자) 또는 base64.
# 생성: openssl rand -hex 32
# 이 값을 잃어버리면 저장된 유저 키를 복호화할 수 없다.
ENCRYPTION_KEY=

# ── 워커 전용 ────────────────────────────────────────────
# 활성 봇 목록 폴링 주기(ms)
WORKER_POLL_INTERVAL_MS=5000

# ── AI 기능 (해설·전략빌더·채팅) ──────────────────────────
# 없으면 AI 기능만 비활성화되고 앱·워커는 정상 동작한다.
# ⚠️ 비용 주의: 자동 해설을 켜면 1분봉 봇 하나당 하루 1,440회 호출이 된다.
#    현재는 유저가 직접 누를 때만 호출하도록 되어 있다.
ANTHROPIC_API_KEY=
